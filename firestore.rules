rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "tarekmoh123@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN')
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isManagerOf(userId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(userId)) &&
        get(/databases/$(database)/documents/users/$(userId)).data.managerId == request.auth.uid;
    }

    function isManagerLevel() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgLevel in ['CEO', 'GM', 'AGM', 'DM', 'SH', 'SP'];
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow users to create their own profile, or admins to create any profile
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Allow users to update their own profile (but not role), admins to update any,
      // or managers to update their subordinates (but not role)
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) ||
        isAdmin() ||
        ((resource.data.managerId == request.auth.uid || isManagerLevel()) && request.resource.data.role == resource.data.role)
      );
      // Allow users to delete their own profile (e.g. during migration from bulk upload) or admins
      allow delete: if isAdmin() || (isAuthenticated() && 'email' in resource.data && resource.data.email.lower() == request.auth.token.email.lower());
    }

    match /skills/{skillId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /jobProfiles/{jobProfileId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /assessments/{assessmentId} {
      allow read: if isAuthenticated();
      // Users can create assessments where they are the rater
      allow create: if isAuthenticated() && (request.resource.data.raterId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.raterId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /activityLogs/{logId} {
      allow read: if isAuthenticated();
      // Anyone can create a log, but only admins can update/delete
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /evidences/{evidenceId} {
      allow read: if isAuthenticated();
      // Users can create their own evidence
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      // Users can update their own evidence (if pending), admins/managers to update any
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING') || 
        isAdmin() ||
        isManagerOf(resource.data.userId) || 
        isManagerLevel()
      );
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // System/Admins can create notifications for anyone
      allow create: if isAuthenticated();
      // Users can update their own notifications (e.g., mark as read)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /assessmentCycles/{cycleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /nominations/{nominationId} {
      allow read: if isAuthenticated();
      // Users can create nominations
      allow create: if isAuthenticated() && request.resource.data.nominatorId == request.auth.uid;
      // Users can update nominations if they are the rater (to approve/reject)
      allow update: if isAuthenticated() && (resource.data.raterId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /scheduledAssessments/{assessmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /trainingCourses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}

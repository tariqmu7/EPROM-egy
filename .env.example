# Firebase Web App configuration.
# Copy this file to `.env.local` (development) and `.env.production` (build),
# then fill in the values from Firebase Console > Project settings > Your apps.
# These files are gitignored and must NOT be committed.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Bootstrap admin email — granted admin access before any user holds the ADMIN
# role (first-run / recovery). Must match the email used to sign up.
# Also consumed by `npm run rules:build` to generate firestore.rules.
VITE_BOOTSTRAP_ADMIN_EMAIL=
